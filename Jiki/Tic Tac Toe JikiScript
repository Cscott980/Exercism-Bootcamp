  stroke_color_hex(color)
  rectangle(5,5,90,90)
  line(5,35,95,35)
  line(5,65,95,65)
  line(35,5,35,95)
  line(65,5,65,95)
end
function draw do 
  fill_color_rgba(96, 79, 205, 0.85)
  rectangle(0,0,100,100)
  write("The game was a draw!")
end
function o_wins do
  fill_color_rgba(96, 79, 205, 0.85)
  rectangle(0,0,100,100)
  write("The o's won!")
end
function x_wins do
  fill_color_rgba(96, 79, 205, 0.85)
